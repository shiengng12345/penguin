{
  "identifier": "default",
  "description": "Default capability — main window + auth-popover popup",
  "windows": ["main", "auth-popover"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-kill",
    "store:default",
    "updater:default",
    "process:allow-restart",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "npm", "cmd": "npm", "args": true },
        { "name": "node", "cmd": "node", "args": true },
        { "name": "zsh-login", "cmd": "/bin/zsh", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "npm", "cmd": "npm", "args": true },
        { "name": "node", "cmd": "node", "args": true },
        { "name": "zsh-login", "cmd": "/bin/zsh", "args": true }
      ]
    }
  ]
}
