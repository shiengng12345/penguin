{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-web/refs/heads/main/nicegram-schemas/tauri-v2/tauri.conf.json",
  "productName": "Penguin",
  "version": "1.0.0",
  "identifier": "com.pengvi.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && cp .pengvi.config.json ~/.pengvi/config.json"
  },
  "app": {
    "windows": [
      {
        "title": "Penguin",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../.pengvi.config.json"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDNkE0MDlDRjM5MjE2MEUKUldRT0ZwTHpuRUJxVEdzaVY0L0dKWUk2b1dDNjRHOWREVjNCNW11Ti9HbmhJOGU3bWxDSzE4TXIK",
      "endpoints": [
        "https://github.com/shiengng12345/penguin/releases/latest/download/latest.json"
      ]
    }
  }
}
