{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-web/refs/heads/main/nicegram-schemas/tauri-v2/tauri.conf.json",
  "productName": "Penguin",
  "version": "1.10.1",
  "identifier": "com.pengvi.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1430",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Penguin",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' http://localhost:1430; style-src 'self' 'unsafe-inline' http://localhost:1430; img-src 'self' asset: data: blob: https: http:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:1430 ws://localhost:1430 https: http:; frame-src 'self' https: http: data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../.penguin.config.json",
      "../packages/mcp/package.json",
      "../packages/mcp/dist/index.js"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRGRkVBRTY3Nzk4QUEyRDIKUldUU29vcDVaNjcrVHo4T2JXM0RMUC9rTGNJeUNZM0wyZXhjZHlYODZIZXc3OVZaaEc2YnNLcEwK",
      "endpoints": [
        "https://github.com/shiengng12345/penguin/releases/latest/download/latest.json"
      ]
    }
  }
}
